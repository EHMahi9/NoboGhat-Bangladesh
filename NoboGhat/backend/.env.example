# Copy this file to .env for local development. Never commit real credentials.
DB_URL=jdbc:mysql://localhost:3306/noboghat?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=replace-with-your-local-password

# Optional local port. Railway provides PORT automatically.
SERVER_PORT=8080

# Comma-separated browser origins allowed to call the API directly.
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
FRONTEND_URL=http://localhost:5500

# Keep this private. Generate a value of at least 32 characters for production.
JWT_SECRET=replace-with-a-long-random-secret-of-at-least-32-characters

# Optional initial administrator. It is created only once if this phone does not exist.
ADMIN_PHONE=
ADMIN_PASSWORD=

# Google login is optional. Add these after creating an OAuth client in Google Cloud.
# Do not put these credentials in Git.
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=
