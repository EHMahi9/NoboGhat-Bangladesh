# Copy this file to .env for local development. Never commit real credentials.
DB_URL=jdbc:mysql://localhost:3306/noboghat?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=replace-with-your-local-password

# Optional local port. Railway provides PORT automatically.
SERVER_PORT=8080

# Comma-separated browser origins allowed to call the API directly.
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
